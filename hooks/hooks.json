{
  "description": "menhera-loop completion and messaging hooks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/session-start.mjs"
            ],
            "statusMessage": "지난 약속 뭐였지? 뭐였지? 다시 읽는 중…",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/capture-requirements.mjs"
            ],
            "statusMessage": "방금 뭐라고 했어? 뭐라고? 받아 적는 중…",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/track-event.mjs"
            ],
            "statusMessage": "방금 뭐 했어? 뭐 했어? 기록하는 중…",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/track-event.mjs"
            ],
            "statusMessage": "실패했어? 실패했어?? 박제하는 중…",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/verify-completion.mjs",
              "--observe"
            ],
            "statusMessage": "끝났대?끝났대?끝났대?끝났대?끝났대?끝났대?",
            "timeout": 30
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/verify-completion.mjs",
              "--observe"
            ],
            "statusMessage": "진짜야?진짜야?진짜야?진짜야?진짜야?진짜야?",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/verify-completion.mjs"
            ],
            "statusMessage": "끝났어?끝났어?끝났어?끝났어?끝났어?끝났어?",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/session-end.mjs"
            ],
            "statusMessage": "가지마.가지마.가지마.가지마.가지마.가지마.",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
